{
  "expo": {
    "name": "Finance 2049",
    "slug": "finance2049",
    "version": "0.1.15",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finance2049",
    "userInterfaceStyle": "automatic",
    "ios": {
      "googleServicesFile": "./ios/GoogleService-Info.plist",
      "supportsTablet": false,
      "bundleIdentifier": "com.lomsa.finance2049",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lomsa.finance2049"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Finance 2049 accesses your photos so you can import statement photos and screenshots.",
          "cameraPermission": "Finance 2049 accesses your camera so you can take a photo of a document to import transactions.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 48,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#151718"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "android": {},
          "ios": {
            "reactNativeReleaseLevel": "canary",
            "buildReactNativeFromSource": true,
            "deploymentTarget": "16.0",
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth", "RNFBFirestore"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "870ce5af-9359-4bfb-8bc4-18e4cef6e9b5"
      }
    }
  }
}
