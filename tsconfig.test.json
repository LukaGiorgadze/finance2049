{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "outDir": ".test-dist",
    "rootDir": ".",
    "noEmit": false,
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noCheck": true
  },
  "include": [
    "lib/store/**/*.ts",
    "lib/crashlytics.ts",
    "tests/**/*.ts"
  ]
}
